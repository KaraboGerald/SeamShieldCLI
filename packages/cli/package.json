  },
  "devDependencies": {
    "@seamshield/core": "workspace:*",
    "@seamshield/rules": "workspace:*",
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.6"
