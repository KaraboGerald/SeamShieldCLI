{
  "name": "@seamshield/cli",
  "version": "0.3.28",
  "description": "Community source-private repository scanner and local control engine for AI-built projects",
  "type": "module",
  "license": "MIT",
  "homepage": "https://seamshield.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KaraboGerald/SeamShieldCLI.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/KaraboGerald/SeamShieldCLI/issues"
  },
  "keywords": [
    "security",
    "scanner",
    "cli",
